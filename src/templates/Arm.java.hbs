package frc.robot.subsystems;

import static edu.wpi.first.units.Units.*;

{{!-- Dynamic Imports based on Motor Controller Type --}}
{{#if (eq motorControllerType 'SparkMax')}}
import com.revrobotics.spark.SparkLowLevel.MotorType;
import com.revrobotics.spark.SparkMax;
import yams.motorcontrollers.local.SparkWrapper;
{{/if}}
{{#if (eq motorControllerType 'SparkFlex')}}
import com.revrobotics.spark.SparkLowLevel.MotorType;
import com.revrobotics.spark.SparkFlex;
import yams.motorcontrollers.local.SparkFlexWrapper;
{{/if}}
{{#if (eq motorControllerType 'TalonFX')}}
import com.ctre.phoenix6.hardware.TalonFX;
import yams.motorcontrollers.local.TalonFXWrapper;
{{/if}}
{{#if (eq motorControllerType 'TalonFXS')}}
import com.ctre.phoenix6.hardware.TalonFXS;
import yams.motorcontrollers.local.TalonFXSWrapper;
{{/if}}

import edu.wpi.first.math.controller.ArmFeedforward;
import edu.wpi.first.math.system.plant.DCMotor;
import edu.wpi.first.units.measure.Angle;
import edu.wpi.first.wpilibj2.command.Command;
import edu.wpi.first.wpilibj2.command.SubsystemBase;
import yams.mechanisms.config.ArmConfig;
import yams.mechanisms.positional.Arm;
import yams.motorcontrollers.SmartMotorController;
import yams.motorcontrollers.SmartMotorControllerConfig;
import yams.motorcontrollers.SmartMotorControllerConfig.ControlMode;
import yams.motorcontrollers.SmartMotorControllerConfig.MotorMode;
import yams.motorcontrollers.SmartMotorControllerConfig.TelemetryVerbosity;
import yams.gearing.GearBox;
import yams.gearing.MechanismGearing;

public class {{subsystemName}} extends SubsystemBase {

// ═══════════════════════════════════════════════════════════════════════════
// 1. SmartMotorController Configuration
// ═══════════════════════════════════════════════════════════════════════════
private SmartMotorControllerConfig smcConfig = new SmartMotorControllerConfig(this)
// Control Mode
.withControlMode(ControlMode.{{controlMode}})
// PID with velocity/acceleration constraints
.withClosedLoopController(
{{pid.kP}}, {{pid.kI}}, {{pid.kD}},
DegreesPerSecond.of({{maxVelocity}}),
DegreesPerSecondPerSecond.of({{maxAcceleration}}))
// Simulation PID (can differ from real)
.withSimClosedLoopController({{simPid.kP}}, {{simPid.kI}}, {{simPid.kD}})
// Feedforward (ArmFeedforward for gravity compensation)
.withFeedforward(new ArmFeedforward({{ff.kS}}, {{ff.kG}}, {{ff.kV}}{{#if ff.kA}}, {{ff.kA}}{{/if}}))
.withSimFeedforward(new ArmFeedforward({{simFf.kS}}, {{simFf.kG}}, {{simFf.kV}}{{#if simFf.kA}}, {{simFf.kA}}{{/if}}))
// Soft Limits (motor controller enforced)
.withSoftLimit(Degrees.of({{minSoftLimit}}), Degrees.of({{maxSoftLimit}}))
// Gearing
.withGearing(new MechanismGearing(GearBox.fromReductionStages({{gearingStages}})))
// Motor Settings
.withMotorInverted({{inverted}})
.withIdleMode(MotorMode.{{idleMode}})
.withStatorCurrentLimit(Amps.of({{statorCurrentLimit}}))
.withSupplyCurrentLimit(Amps.of({{supplyCurrentLimit}}))
.withClosedLoopRampRate(Seconds.of({{rampRate}}))
.withOpenLoopRampRate(Seconds.of({{rampRate}}))
// Telemetry
.withTelemetry("{{subsystemName}}Motor", TelemetryVerbosity.HIGH);

// ═══════════════════════════════════════════════════════════════════════════
// 2. Motor Controller Initialization
// ═══════════════════════════════════════════════════════════════════════════
{{#if (eq motorControllerType 'SparkMax')}}
private SparkMax motor = new SparkMax({{canId}}, MotorType.kBrushless);
private SmartMotorController smartMotorController = new SparkWrapper(motor, DCMotor.get{{motorModel}}(1), smcConfig);
{{/if}}
{{#if (eq motorControllerType 'SparkFlex')}}
private SparkFlex motor = new SparkFlex({{canId}}, MotorType.kBrushless);
private SmartMotorController smartMotorController = new SparkFlexWrapper(motor, DCMotor.get{{motorModel}}(1),
smcConfig);
{{/if}}
{{#if (eq motorControllerType 'TalonFX')}}
private TalonFX motor = new TalonFX({{canId}});
private SmartMotorController smartMotorController = new TalonFXWrapper(motor, DCMotor.get{{motorModel}}(1), smcConfig);
{{/if}}
{{#if (eq motorControllerType 'TalonFXS')}}
private TalonFXS motor = new TalonFXS({{canId}});
private SmartMotorController smartMotorController = new TalonFXSWrapper(motor, DCMotor.get{{motorModel}}(1), smcConfig);
{{/if}}

// ═══════════════════════════════════════════════════════════════════════════
// 3. Arm Mechanism Configuration
// ═══════════════════════════════════════════════════════════════════════════
private ArmConfig armConfig = new ArmConfig(smartMotorController)
.withLength(Meters.of({{armLength}}))
.withMass(Pounds.of({{mass}}))
.withStartingPosition(Degrees.of({{startingAngle}}))
.withHorizontalZero(Degrees.of({{horizontalZero}}))
.withHardLimit(Degrees.of({{minHardLimit}}), Degrees.of({{maxHardLimit}}))
.withTelemetry("{{subsystemName}}", TelemetryVerbosity.HIGH);

private Arm arm = new Arm(armConfig);

/** Creates a new {{subsystemName}}. */
public {{subsystemName}}() {}

/**
* Set the angle of the arm.
* @param angle Target angle to move to.
* @return Command that moves the arm to the target angle.
*/
public Command setAngle(Angle angle) {
return arm.setAngle(angle);
}

/**
* Move the arm with duty cycle (open loop).
* @param dutyCycle Speed from -1.0 to 1.0.
* @return Command that runs the arm at the specified duty cycle.
*/
public Command set(double dutyCycle) {
return arm.set(dutyCycle);
}

/**
* Get the current angle of the arm.
* @return Current arm angle.
*/
public Angle getAngle() {
return arm.getAngle();
}

/**
* Run SysId characterization routine.
* @return SysId command for tuning.
*/
public Command sysId() {
return arm.sysId(Volts.of(7), Volts.of(2).per(Second), Seconds.of(4));
}

@Override
public void periodic() {
arm.updateTelemetry();
}

@Override
public void simulationPeriodic() {
arm.simIterate();
}
}