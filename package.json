{
  "name": "frc-workbench",
  "displayName": "FRC Workbench",
  "description": "A collection of helpful tools for FRC teams, including PID tuning and PathPlanner previews.",
  "version": "0.0.2",
  "publisher": "riteshrajas",
  "repository": {
    "type": "git",
    "url": "https://github.com/riteshrajas/frc-vs-code-plugin"
  },
  "icon": "images/image.png",
  "engines": {
    "vscode": "^1.104.0"
  },
  "categories": [
    "Other",
    "Visualization",
    "Programming Languages"
  ],
  "activationEvents": [
    "onCommand:frc-vs-code-plugin.createSubsystem",
    "onCommand:frc-vs-code-plugin.manageConstants",
    "onCommand:frc-vs-code-plugin.pidTuner",
    "onCustomEditor:frc-vs-code-plugin.pathPlannerPreview",
    "onCustomEditor:frc-vs-code-plugin.autoPreview"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "frc-vs-code-plugin.createSubsystem",
        "title": "FRC: Create Advanced Subsystem"
      },
      {
        "command": "frc-vs-code-plugin.wrapInstantCommand",
        "title": "FRC: Wrap in InstantCommand"
      },
      {
        "command": "frc-vs-code-plugin.manageConstants",
        "title": "FRC: Constants Manager"
      },
      {
        "command": "frc-vs-code-plugin.createCommandGroup",
        "title": "FRC: Command Composer"
      },
      {
        "command": "frc-vs-code-plugin.openManagerFromEditor",
        "title": "Open in Constants Manager",
        "icon": "$(edit)"
      },
      {
        "command": "frc-vs-code-plugin.preFlightChecklist",
        "title": "FRC: Pre-Flight Checklist",
        "icon": "$(rocket)"
      },
      {
        "command": "frc-vs-code-plugin.buildCode",
        "title": "FRC: Build Code",
        "icon": "$(tools)"
      },
      {
        "command": "frc-vs-code-plugin.simulateCode",
        "title": "FRC: Simulate Robot Code",
        "icon": "$(play)"
      },
      {
        "command": "frc-vs-code-plugin.pidTuner",
        "title": "FRC: PID Tuner",
        "icon": "$(graph)"
      },
      {
        "command": "frc-vs-code-plugin.installCustomPID",
        "title": "FRC: Install Tuneable PID Class"
      },
      {
        "command": "frc-vs-code-plugin.helloWorld",
        "title": "Hello World"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "frc-vs-code-plugin.openManagerFromEditor",
          "when": "resourceFilename =~ /^(Constants|RobotMap)\\.java$/",
          "group": "navigation"
        },
        {
          "command": "frc-vs-code-plugin.buildCode",
          "when": "resourceLangId == java",
          "group": "navigation@1"
        },
        {
          "command": "frc-vs-code-plugin.preFlightChecklist",
          "when": "resourceLangId == java",
          "group": "navigation@2"
        },
        {
          "command": "frc-vs-code-plugin.simulateCode",
          "when": "resourceLangId == java",
          "group": "navigation@3"
        }
      ],
      "editor/context": [
        {
          "command": "frc-vs-code-plugin.createSubsystem",
          "when": "editorLangId == java",
          "group": "frc@1"
        },
        {
          "command": "frc-vs-code-plugin.manageConstants",
          "when": "editorLangId == java",
          "group": "frc@2"
        },
        {
          "command": "frc-vs-code-plugin.createCommandGroup",
          "when": "editorLangId == java",
          "group": "frc@3"
        },
        {
          "command": "frc-vs-code-plugin.wrapInstantCommand",
          "when": "editorLangId == java && editorHasSelection",
          "group": "frc@4"
        }
      ],
      "explorer/context": [
        {
          "command": "frc-vs-code-plugin.createSubsystem",
          "when": "explorerResourceIsFolder",
          "group": "frc@1"
        },
        {
          "command": "frc-vs-code-plugin.manageConstants",
          "when": "explorerResourceIsFolder",
          "group": "frc@2"
        },
        {
          "command": "frc-vs-code-plugin.createCommandGroup",
          "when": "explorerResourceIsFolder",
          "group": "frc@3"
        }
      ]
    },
    "configuration": {
      "title": "FRC Plugin",
      "properties": {
        "frcPlugin.constantsFileName": {
          "type": "string",
          "enum": [
            "Constants.java",
            "RobotMap.java"
          ],
          "default": "RobotMap.java",
          "description": "Name of the constants/robot map file"
        },
        "frcPlugin.autoOpenManager": {
          "type": "string",
          "enum": [
            "always",
            "ask",
            "never"
          ],
          "default": "ask",
          "enumDescriptions": [
            "Always open the manager when opening the constants file",
            "Ask each time",
            "Never open the manager automatically"
          ],
          "description": "Behavior when opening the constants file"
        }
      }
    },
    "customEditors": [
      {
        "viewType": "frc-vs-code-plugin.pathPlannerPreview",
        "displayName": "PathPlanner Preview",
        "selector": [
          {
            "filenamePattern": "*.path"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "frc-vs-code-plugin.autoPreview",
        "displayName": "Auto Routine Preview",
        "selector": [
          {
            "filenamePattern": "*.auto"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.104.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.1"
  },
  "dependencies": {
    "wpilib-nt-client": "^1.7.2",
    "wpilib-ws-robot": "^0.0.7"
  }
}
