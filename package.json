{
  "name": "frc-workbench",
  "displayName": "FRC Workbench",
  "description": "A collection of helpful tools for FRC teams, including PID tuning and PathPlanner previews.",
  "version": "0.1.1",
  "publisher": "riteshrajas",
  "repository": {
    "type": "git",
    "url": "https://github.com/riteshrajas/frc-workbench"
  },
  "icon": "images/image.png",
  "engines": {
    "vscode": "^1.89.0"
  },
  "categories": [
    "Other",
    "Visualization",
    "Programming Languages"
  ],
  "activationEvents": [
    "onCustomEditor:frc-workbench.pathPlannerPreview",
    "onCustomEditor:frc-workbench.autoPreview"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "frc-workbench.createSubsystem",
        "title": "Subsystem Creator"
      },
      {
        "command": "frc-workbench.createCommandGroup",
        "title": "Command Creator"
      },
      {
        "command": "frc-workbench.wrapInstantCommand",
        "title": "Wrap in InstantCommand"
      },
      {
        "command": "frc-workbench.manageConstants",
        "title": "Constants Manager"
      },
      {
        "command": "frc-workbench.openManagerFromEditor",
        "title": "Open Constants Manager",
        "icon": "$(edit)"
      },
      {
        "command": "frc-workbench.preFlightChecklist",
        "title": "Pre-Flight Checklist",
        "icon": "$(rocket)"
      },
      {
        "command": "frc-workbench.buildCode",
        "title": "Build Code",
        "icon": "$(tools)"
      },
      {
        "command": "frc-workbench.simulateCode",
        "title": "Simulate Robot Code",
        "icon": "$(play)"
      },
      {
        "command": "frc-workbench.pidTuner",
        "title": "PID Tuner",
        "icon": "$(graph)"
      },
      {
        "command": "frc-workbench.installCustomPID",
        "title": "Install Tuneable PID Class"
      },
      {
        "command": "frc-workbench.checkAndOpenYAMG",
        "title": "Open YAMG (Mechanism Generator)"
      }
    ],
    "submenus": [
      {
        "id": "frc-workbench.submenu",
        "label": "FRC"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "frc-workbench.openManagerFromEditor",
          "when": "resourceFilename =~ /^(Constants|RobotMap)\\.java$/",
          "group": "navigation"
        },
        {
          "command": "frc-workbench.buildCode",
          "when": "resourceLangId == java",
          "group": "navigation@1"
        },
        {
          "command": "frc-workbench.preFlightChecklist",
          "when": "resourceLangId == java",
          "group": "navigation@2"
        },
        {
          "command": "frc-workbench.simulateCode",
          "when": "resourceLangId == java",
          "group": "navigation@3"
        }
      ],
      "editor/context": [
        {
          "submenu": "frc-workbench.submenu",
          "group": "frc",
          "when": "editorLangId == java"
        }
      ],
      "explorer/context": [
        {
          "submenu": "frc-workbench.submenu",
          "group": "frc",
          "when": "explorerResourceIsFolder"
        }
      ],
      "frc-workbench.submenu": [
        {
          "command": "frc-workbench.createSubsystem",
          "group": "1_creation@1"
        },
        {
          "command": "frc-workbench.createCommandGroup",
          "group": "1_creation@2"
        },
        {
          "command": "frc-workbench.manageConstants",
          "group": "2_management@1"
        },
        {
          "command": "frc-workbench.pidTuner",
          "group": "2_management@2"
        },
        {
          "command": "frc-workbench.installCustomPID",
          "group": "2_management@3"
        },
        {
          "command": "frc-workbench.buildCode",
          "group": "3_tools@1"
        },
        {
          "command": "frc-workbench.simulateCode",
          "group": "3_tools@2"
        },
        {
          "command": "frc-workbench.preFlightChecklist",
          "group": "3_tools@3"
        },
        {
          "command": "frc-workbench.wrapInstantCommand",
          "group": "3_tools@4",
          "when": "editorHasSelection"
        }
      ]
    },
    "configuration": {
      "title": "FRC Plugin",
      "properties": {
        "frcPlugin.constantsFileName": {
          "type": "string",
          "enum": [
            "Constants.java",
            "RobotMap.java"
          ],
          "default": "RobotMap.java",
          "description": "Name of the constants/robot map file"
        },
        "frcPlugin.autoOpenManager": {
          "type": "string",
          "enum": [
            "always",
            "ask",
            "never"
          ],
          "default": "ask",
          "enumDescriptions": [
            "Always open the manager when opening the constants file",
            "Ask each time",
            "Never open the manager automatically"
          ],
          "description": "Behavior when opening the constants file"
        }
      }
    },
    "customEditors": [
      {
        "viewType": "frc-workbench.pathPlannerPreview",
        "displayName": "PathPlanner Preview",
        "selector": [
          {
            "filenamePattern": "*.path"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "frc-workbench.autoPreview",
        "displayName": "Auto Routine Preview",
        "selector": [
          {
            "filenamePattern": "*.auto"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.90.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.1"
  },
  "dependencies": {
    "wpilib-nt-client": "^1.7.2",
    "wpilib-ws-robot": "^0.0.7"
  }
}